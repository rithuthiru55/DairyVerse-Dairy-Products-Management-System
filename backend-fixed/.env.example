# ═══════════════════════════════════════════════════════════════
#  DairyVerse – Environment Variables
#  1. Copy:  cp .env.example .env
#  2. Fill in ALL values below
#  3. NEVER commit .env to git — add it to .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────────────────
APP_NAME=DairyVerse
NODE_ENV=production
PORT=5000

# ─── Database ──────────────────────────────────────────────────
# MongoDB Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/dairyverse?retryWrites=true&w=majority
# Local:          mongodb://localhost:27017/dairyverse
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/dairyverse?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────
CLIENT_URL=https://yourdomain.com

# ─── Admin Registration ────────────────────────────────────────
# Secret code required to register admin accounts
ADMIN_REGISTRATION_CODE=CHANGE_THIS_SECRET_CODE

# ─── OTP Security ──────────────────────────────────────────────
# Random pepper to strengthen OTP hashing
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_PEPPER=REPLACE_WITH_32_BYTE_HEX_STRING

# ─── Redis (Recommended for production OTP store) ──────────────
# If not set, OTPs are stored in-memory (resets on restart)
# Redis Cloud:   redis://default:password@host:port
# Local:         redis://localhost:6379
REDIS_URL=redis://default:PASSWORD@your-redis-host:6379

# ─── Twilio – SMS OTP ──────────────────────────────────────────
# Get from: https://console.twilio.com
# Account SID and Auth Token are on the Twilio Console homepage
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Use either a Messaging Service SID (recommended for production)
# OR a plain Twilio phone number — not both.
# Messaging Service SID (supports sender pool, alphanumeric sender ID):
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OR plain phone number (E.164 format):
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── SMTP – Email OTP ──────────────────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-app-password   ← Use an App Password, not your Gmail password
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=your_sendgrid_api_key
#
# Mailgun example:
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_USER=postmaster@yourdomain.com
#   SMTP_PASS=your_mailgun_smtp_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Optional: override the "From" address display name
SMTP_FROM=DairyVerse <no-reply@yourdomain.com>
